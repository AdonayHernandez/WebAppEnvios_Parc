@model IEnumerable<WebAppEnvios.Models.Destinatario>

@{
    ViewData["Title"] = "Mis Destinatarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Mis <span style="color: var(--secondary);">Destinatarios</span></h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        + Añadir Nuevo Destinatario
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                <th>Contacto</th>
                <th>Dirección Principal</th>
                <th>Ubicación</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td class="fw-bold text-dark">
                    @Html.DisplayFor(modelItem => item.Nombre)
                </td>
                <td>
                    <span class="badge bg-light text-dark border"><i class="bi bi-telephone"></i> @item.Telefono</span>
                </td>
                <td class="text-muted">
                    @Html.DisplayFor(modelItem => item.Direccion)
                </td>
                <td>
                    @item.Ciudad, <span class="fw-medium">@item.Pais</span>
                </td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.DestinatarioId" class="btn btn-sm btn-outline-primary">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.DestinatarioId" class="btn btn-sm btn-outline-info">Ver</a>
                    <a asp-action="Delete" asp-route-id="@item.DestinatarioId" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </td>
            </tr>
        }
        @if(!Model.Any()){
            <tr>
                <td colspan="5" class="text-center p-5 text-muted">Aún no tienes destinatarios registrados en tu libreta.</td>
            </tr>
        }
        </tbody>
    </table>
</div>
