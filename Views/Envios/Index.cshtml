@model IEnumerable<WebAppEnvios.Models.Envio>
@{
    ViewData["Title"] = User.IsInRole("Administrador") ? "Todos los Envíos" : "Mis Envíos";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>⚠️</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>✅</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-primary">➕ Crear Nuevo Envío</a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div style="font-size:4rem;">📭</div>
        <h4 class="mt-3 text-muted">No hay envíos registrados</h4>
        <p class="text-muted">Crea tu primer envío para comenzar.</p>
        <a asp-action="Create" class="btn btn-primary mt-2">Crear Envío</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>N° Seguimiento</th>
                    @if (User.IsInRole("Administrador"))
                    {
                        <th>Cliente</th>
                    }
                    <th>Destinatario</th>
                    <th>Sucursal Origen</th>
                    <th>Fecha Envío</th>
                    <th>Costo</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var badgeClass = item.EstadoEnvio?.NombreEstado switch
                    {
                        "Pendiente"    => "bg-warning text-dark",
                        "Recolectado"  => "bg-info text-dark",
                        "En Tránsito"  => "bg-primary",
                        "En Sucursal"  => "bg-secondary",
                        "Entregado"    => "bg-success",
                        "Cancelado"    => "bg-danger",
                        "No Entregado" => "bg-dark",
                        _              => "bg-secondary"
                    };
                    var isPendiente = item.EstadoEnvio?.NombreEstado == "Pendiente";

                    <tr>
                        <td><code class="text-primary">@(item.NumeroSeguimiento ?? $"SB-{item.EnvioId}")</code></td>
                        @if (User.IsInRole("Administrador"))
                        {
                            <td>@item.Cliente?.Nombre</td>
                        }
                        <td>
                            <strong>@item.Destinatario?.Nombre</strong><br>
                            <small class="text-muted">@item.Destinatario?.Ciudad</small>
                        </td>
                        <td>
                            @if (item.Sucursal != null)
                            {
                                <span>@item.Sucursal.Departamento</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@item.FechaEnvio.ToString("dd/MM/yyyy")</td>
                        <td><strong>$@item.Costo.ToString("0.00")</strong></td>
                        <td>
                            <span class="badge rounded-pill @badgeClass">@item.EstadoEnvio?.NombreEstado</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.EnvioId" class="btn btn-sm btn-outline-primary" title="Ver detalles">🔍</a>
                            <a asp-action="Etiqueta" asp-route-id="@item.EnvioId" class="btn btn-sm btn-outline-secondary" title="Imprimir etiqueta">🏷️</a>
                            @if (User.IsInRole("Administrador") || isPendiente)
                            {
                                <a asp-action="Edit" asp-route-id="@item.EnvioId" class="btn btn-sm btn-outline-warning" title="Editar">✏️</a>
                                <a asp-action="Delete" asp-route-id="@item.EnvioId" class="btn btn-sm btn-outline-danger" title="@(User.IsInRole("Administrador") ? "Eliminar" : "Cancelar")">🗑️</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
