@model WebAppEnvios.Models.Sucursal
@{ ViewData["Title"] = "Nueva Sucursal"; }

<div class="d-flex align-items-center gap-3 mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Sucursales</a>
    <h1 class="mb-0">Nueva Sucursal</h1>
</div>

<div class="row"><div class="col-lg-6">
<div class="card border-0 shadow-sm"><div class="card-body">
<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="Nombre" class="form-label fw-bold"></label>
        <input asp-for="Nombre" class="form-control" placeholder="SmallBox Nombre Ciudad"/>
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Departamento" class="form-label fw-bold"></label>
        <select asp-for="Departamento" class="form-select">
            <option value="">— Seleccionar —</option>
            <option>Ahuachapán</option><option>Cabañas</option><option>Chalatenango</option>
            <option>Cuscatlán</option><option>La Libertad</option><option>La Paz</option>
            <option>La Unión</option><option>Morazán</option><option>San Miguel</option>
            <option>San Salvador</option><option>San Vicente</option><option>Santa Ana</option>
            <option>Sonsonate</option><option>Usulután</option>
        </select>
        <span asp-validation-for="Departamento" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Direccion" class="form-label fw-bold"></label>
        <input asp-for="Direccion" class="form-control"/>
        <span asp-validation-for="Direccion" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Telefono" class="form-label fw-bold"></label>
        <input asp-for="Telefono" class="form-control" placeholder="2222-0000"/>
        <span asp-validation-for="Telefono" class="text-danger"></span>
    </div>
    <div class="mb-4 form-check">
        <input asp-for="Activa" class="form-check-input" type="checkbox"/>
        <label asp-for="Activa" class="form-check-label">Sucursal Activa</label>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>
</div></div>
</div></div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
