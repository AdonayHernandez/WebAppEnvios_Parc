@model IEnumerable<WebAppEnvios.Models.Sucursal>
@{ ViewData["Title"] = "Sucursales SmallBox"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>🏢 Sucursales</h1>
    <a asp-action="Create" class="btn btn-primary">➕ Nueva Sucursal</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Departamento</th>
                <th>Dirección</th>
                <th>Teléfono</th>
                <th>Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td><strong>@s.Nombre</strong></td>
                    <td>@s.Departamento</td>
                    <td>@s.Direccion</td>
                    <td>@s.Telefono</td>
                    <td>
                        @if (s.Activa)
                        { <span class="badge bg-success">Activa</span> }
                        else
                        { <span class="badge bg-danger">Inactiva</span> }
                    </td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@s.SucursalId" class="btn btn-sm btn-outline-primary">🔍</a>
                        <a asp-action="Edit" asp-route-id="@s.SucursalId" class="btn btn-sm btn-outline-warning">✏️</a>
                        <a asp-action="Delete" asp-route-id="@s.SucursalId" class="btn btn-sm btn-outline-danger">🗑️</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
