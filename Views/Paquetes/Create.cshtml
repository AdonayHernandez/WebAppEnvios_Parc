@model WebAppEnvios.Models.Paquete

@{
    ViewData["Title"] = "Agregar Paquete";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="mb-0">Añadir Paquete <span class="text-muted">| Nuevo</span></h1>
    </div>
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-outline-secondary">
            ← Volver a la Lista
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" class="needs-validation">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            
            <div class="form-group mb-4">
                <label asp-for="EnvioId" class="control-label fw-bold mb-2">Seleccione el Envío</label>
                <select asp-for="EnvioId" class="form-select form-select-lg" asp-items="ViewBag.EnvioId">
                    <option value="">-- Seleccionar Envío --</option>
                </select>
            </div>
            
            <div class="form-group mb-4">
                <label asp-for="Peso" class="control-label fw-bold mb-2">Peso del Paquete (Libras/Kg)</label>
                <input asp-for="Peso" class="form-control form-control-lg" type="number" step="0.01" placeholder="Ejemplo: 2.5" />
                <span asp-validation-for="Peso" class="text-danger mt-1 d-block small"></span>
            </div>
            
            <div class="form-group mt-5">
                <button type="submit" class="btn btn-primary btn-lg w-100">
                   Crear Paquete 📦
                </button>
            </div>
        </form>
    </div>
    <div class="col-md-6 d-none d-md-flex align-items-center justify-content-center">
        <div class="text-center p-5" style="background: rgba(79, 70, 229, 0.05); border-radius: 20px;">
            <h3 class="fw-bold mb-3" style="color: var(--primary);">Registra Tus Embalajes</h3>
            <p class="text-muted">Asegúrate de colocar el peso exacto para evitar complicaciones en los costos de envío. Nuestra tarifa se calcula en base a este monto.</p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
